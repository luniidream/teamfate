# Copy to `.env` in the repo root and adjust (`.env` is gitignored).
#
# Production (Netlify): Site configuration → Environment variables — add the same
# names there. Netlify does not use this file on deploy unless you commit `.env`
# (not recommended for secrets).

# Admin login — used by `netlify/functions/api.mjs` and `artifacts/api-server` (local).
# Falls back to `teamfate2025` in code if unset.
ADMIN_PASSWORD=teamfate2025

# Frontend (Vite). Only variables prefixed with VITE_ are exposed to the browser.
# Leave unset for normal Netlify hosting (same-origin `/api`).
# For local dev with API on another port/origin, e.g.:
# VITE_API_BASE_URL=http://localhost:8787

# Local Postgres (Express + Drizzle only — not used by the Netlify serverless app).
# DATABASE_URL=postgresql://user:pass@localhost:5432/team_fate

# Optional — local dev
# PORT=5173
